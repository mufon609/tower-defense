                      "params": {}
                    },
                    {
                      "type": "contact-damage",
                      "params": {
                        "targetTag": "creep",
                        "damage": "$cfg.towerDamage",
                        "selfDestruct": true
                      }
                    },
                    {
                      "type": "health-and-death",
                      "params": {
                        "hp": "$cfg.bulletHp",
                        "lifespan": "$cfg.bulletLifespan",
                        "deathSound": ""
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    },
